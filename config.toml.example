api_token = "apify_api_xxxxxxxxxxxxxxxxxxxx"
username  = "your-apify-username"
db_path   = "jobs.db"

# Directory for job file attachments (created if missing). Files are stored under
# UUID names; the real filename + metadata live in the DB. Default: "uploads".
uploads_dir = "uploads"

# Shared AI engine settings — used by all AI features (viability scoring and
# description reformatting). Each feature may override `model` in its own section.
# [ai]
# api_key = "sk-ant-xxxxxxxxxxxxxxxxxxxx"   # Anthropic API key (or set ANTHROPIC_API_KEY env var)
# model   = "claude-haiku-4-5"              # default Anthropic model (default: claude-haiku-4-5)

# Viability scoring — uses the Anthropic API to rate each job high/medium/low.
# Run `rescore_viability.sh` after ingestion to score new/updated jobs (excludes closed).
# api_key/model are inherited from [ai] (an api_key/model set here still wins as an override).
# RECOMMENDED: set `model` below to a capable model like claude-sonnet-5. The [ai] default is
# cheap Haiku (right for high-volume reformatting), but viability is a real judgment call AND it
# sets the description-aware geo sub-call's model — Haiku there false-POORs remote jobs. The cost
# delta is small (the candidate profile is prompt-cached). See docs/configuration.md for why.
# [viability]
# enabled = true
# model   = "claude-sonnet-5"               # optional per-feature override of [ai].model for scoring (recommended)
# auto_skip            = false              # auto-set low/medium jobs to 'autoskipped' during rescore
# auto_skip_confidence = "low"             # threshold: "low" (only low) or "medium" (low + medium)
# prompt  = """
# Describe yourself as a candidate. Be specific: background, skills, years of
# experience, preferred role types, company stage, and any deal-breakers.
# Example: "I am a senior software engineer with 12 years of Python/cloud
# experience. I want IC or tech-lead roles at Series A–C startups. No Java-only
# shops, no more than 10% travel."
# """
#
# Optional: geographic preferences. When set, each job's location(s) are matched
# against this by a focused, single-purpose AI call, and only the resulting verdict
# ("Geographic fit: PREFERRED/GOOD/ACCEPTABLE/POOR", best→worst) is fed to the main
# scorer — which scores geography far more reliably than making the main call parse a
# multi-city list itself. The four tiers are generic ordinal rungs; YOUR prompt decides
# which locations earn which tier. Put ALL location/remote judgments here (nothing is
# assumed in code), and keep geography OUT of the `prompt` above so it isn't double-judged.
# A POOR verdict (the bottom tier — no location/remote option the candidate can work) forces
# the overall viability to `low`; the other three tiers are advisory to the main scorer.
#
# Include WHERE YOU LIVE: the sub-call also reads each job's description, so it can honor
# eligibility conditions in the prose — e.g. a "remote" role that only accepts residents of
# certain states. It needs your residence to know whether such conditions include you.
#
# Tip: if your ingest tasks already restrict searches to specific geographies (locationSearch),
# a posting whose only stated location is a bare country ("United States") almost certainly
# still falls within one of your target areas — the feed wouldn't have returned it otherwise.
# You can encode that so such vague postings don't get dinged as out-of-area (see below).
# location_prompt = """
# I currently reside in Alexandria, Virginia.
# PREFERRED: DC Metro / Northern Virginia; also fully remote.
# GOOD: Raleigh/RTP and elsewhere in North Carolina.
# ACCEPTABLE: South Carolina.
# POOR: on-site/hybrid whose only locations are outside VA/DC/NC/SC, unless fully remote.
# If a posting's ONLY location is an entire country (e.g. "United States") with no state or
# city, assume it falls within my target areas (my searches are already geographically
# pre-filtered to the tiers above) and treat it as at least ACCEPTABLE.
# """
# location_model = "claude-haiku-4-5"        # optional; overrides the auto-selected sub-call model.
#   When unset: with location_use_description OFF the sub-call is a cheap location match and uses
#   [ai].model. With it ON, reading descriptions needs comprehension, so it uses whatever model
#   viability scoring itself uses — the `model` in this [viability] section if you set one (above),
#   otherwise [ai].model. So if your scoring runs on a capable model (e.g. sonnet) the sub-call
#   inherits it; if your whole setup is on a cheap model, it stays cheap and will false-POOR remote
#   jobs whose descriptions merely mention other regions — set location_model here to fix that.
# location_use_description = true             # optional (default true). When true, the location
#   sub-call also reads each job's description to honor eligibility conditions in the prose
#   (state-restricted remote, relocation) — and needs a capable model (see location_model; the
#   default auto-escalates to your viability model). Set false to skip it: the sub-call then dedups
#   hard by location set (cheaper, fewer calls, a cheap model is fine) but can't see those
#   conditions. Flipping it re-scores.

# AI description reformatting (optional) — at ingest time, hand each description to
# the model and store a cleaned Markdown version that the UI shows instead of the
# regex-based formatter. Formatting only, never content (verified per job); falls
# back to the regex renderer when off / unavailable / the integrity check fails.
# Requires the `markdown` and `bleach` packages and an [ai] api_key. Costs tokens
# (logged in the ingest summary); identical descriptions are formatted once and reused.
# [descriptions]
# use_ai_on_descriptions = true
# model = "claude-haiku-4-5"                # optional per-feature override of [ai].model

# Global defaults — all can be overridden per task.
# reset_on_change  = true   # reset skipped jobs to new if description changes (default: true)
# auto_ghost       = false  # automatically move stale 'applied' jobs to 'ghosted' (default: false)
# auto_ghost_days  = 180    # days since applied_at before auto-ghosting (default: 180)

# Fuzzy near-duplicate detection (global defaults; per-task key overrides).
# fuzzy_dedup = true               # enable near-duplicate grouping for all tasks (default: true)
# fuzzy_desc_threshold = 0.85      # min description similarity to consider a near-duplicate (0–1, default: 0.85)
# fuzzy_title_threshold = 0.6      # min title similarity pre-filter before description check (0–1, default: 0.6)
# inherit_canonical_status = true  # new duplicate inherits the canonical job's status (default: true)

# Map label keys to display names shown in the UI filter bar.
# If a label has no entry here it is shown uppercased.
[labels]
dc = "DC/DMV"
nc = "NC"

[[tasks]]
name  = "my-dc-va-search"
label = "dc"             # short key stored in the database; shown in the UI filter bar
# actor = "linkedin"    # optional: "linkedin" (default) or "careersite"
# exclude_ats_duplicates = true  # optional: skip results already covered by a career-site task
# reset_on_change = true         # optional: overrides global default for this task
# fuzzy_dedup = true             # optional: overrides global default for this task

[[tasks]]
name  = "my-dc-va-search-career-sites"
label = "dc"             # same label — career-site results join the same filter group
actor = "careersite"     # use fantastic-jobs/career-site-job-listing-api

[[tasks]]
name  = "my-nc-search"
label = "nc"

# ── Alternative: one generic task + per-schedule label overrides ──────────────
# Instead of one task per region, create a single generic task and configure
# multiple Apify schedules, each with an input override that names the label:
#
#   Apify schedule override (JSON):
#     { "location": "Washington DC, Maryland, Virginia", "_jobsearch_label": "dc" }
#
# Then set label_from_input to the field name. `label` is used as a fallback
# if the field is absent from the run input.
#
# [[tasks]]
# name             = "my-generic-linkedin"
# label            = "unknown"          # fallback if _jobsearch_label missing
# label_from_input = "_jobsearch_label" # read label from this run input field
#
# [[tasks]]
# name             = "my-generic-careersite"
# label            = "unknown"
# label_from_input = "_jobsearch_label"
# actor            = "careersite"

# ── Company-name normalization (optional) ─────────────────────────────────────
# Job feeds spell the same employer inconsistently (e.g. "Sirius XM" vs
# "Sirius XM Radio"). List each variant on the left and the canonical name to
# store on the right. Matching is case-insensitive and exact (whole field, after
# trimming) — it is NOT substring or fuzzy. Aliases are applied to newly ingested
# and re-seen jobs only; existing rows are normalized the next time that posting
# reappears in a feed. Aliases are not chained: map every variant straight to the
# final name.
#
# [company_aliases]
# "Sirius XM"       = "SiriusXM"
# "Sirius XM Radio" = "SiriusXM"
