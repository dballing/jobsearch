api_token = "apify_api_xxxxxxxxxxxxxxxxxxxx"
username  = "your-apify-username"
db_path   = "jobs.db"

[[tasks]]
name    = "my-dc-va-search"
label   = "dc"           # required: short key stored in the database
display = "DC/DMV"       # optional: pretty name shown in the UI filter bar (defaults to label uppercased)

[[tasks]]
name    = "my-nc-search"
label   = "nc"           # required
display = "NC"           # optional
