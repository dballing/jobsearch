api_token = "apify_api_xxxxxxxxxxxxxxxxxxxx"
username  = "your-apify-username"
db_path   = "jobs.db"

# Directory for job file attachments (created if missing). Files are stored under
# UUID names; the real filename + metadata live in the DB. Default: "uploads".
uploads_dir = "uploads"

# Viability scoring — uses the Anthropic API to rate each job high/medium/low.
# Run `rescore_viability.sh` after ingestion to score new/updated jobs (excludes closed).
# [viability]
# enabled = true
# api_key = "sk-ant-xxxxxxxxxxxxxxxxxxxx"   # Anthropic API key (or set ANTHROPIC_API_KEY env var)
# model   = "claude-haiku-4-5"              # optional: Anthropic model (default: claude-haiku-4-5)
# auto_skip            = false              # auto-set low/medium jobs to 'autoskipped' during rescore
# auto_skip_confidence = "low"             # threshold: "low" (only low) or "medium" (low + medium)
# prompt  = """
# Describe yourself as a candidate. Be specific: background, skills, years of
# experience, preferred role types, company stage, and any deal-breakers.
# Example: "I am a senior software engineer with 12 years of Python/cloud
# experience. I want IC or tech-lead roles at Series A–C startups. No Java-only
# shops, no more than 10% travel."
# """

# Global defaults — all can be overridden per task.
# reset_on_change  = true   # reset skipped jobs to new if description changes (default: true)
# auto_ghost       = false  # automatically move stale 'applied' jobs to 'ghosted' (default: false)
# auto_ghost_days  = 180    # days since applied_at before auto-ghosting (default: 180)

# Fuzzy near-duplicate detection (global defaults; per-task key overrides).
# fuzzy_dedup = true               # enable near-duplicate grouping for all tasks (default: true)
# fuzzy_desc_threshold = 0.85      # min description similarity to consider a near-duplicate (0–1, default: 0.85)
# fuzzy_title_threshold = 0.6      # min title similarity pre-filter before description check (0–1, default: 0.6)
# inherit_canonical_status = true  # new duplicate inherits the canonical job's status (default: true)

# Map label keys to display names shown in the UI filter bar.
# If a label has no entry here it is shown uppercased.
[labels]
dc = "DC/DMV"
nc = "NC"

[[tasks]]
name  = "my-dc-va-search"
label = "dc"             # short key stored in the database; shown in the UI filter bar
# actor = "linkedin"    # optional: "linkedin" (default) or "careersite"
# exclude_ats_duplicates = true  # optional: skip results already covered by a career-site task
# reset_on_change = true         # optional: overrides global default for this task
# fuzzy_dedup = true             # optional: overrides global default for this task

[[tasks]]
name  = "my-dc-va-search-career-sites"
label = "dc"             # same label — career-site results join the same filter group
actor = "careersite"     # use fantastic-jobs/career-site-job-listing-api

[[tasks]]
name  = "my-nc-search"
label = "nc"

# ── Alternative: one generic task + per-schedule label overrides ──────────────
# Instead of one task per region, create a single generic task and configure
# multiple Apify schedules, each with an input override that names the label:
#
#   Apify schedule override (JSON):
#     { "location": "Washington DC, Maryland, Virginia", "_jobsearch_label": "dc" }
#
# Then set label_from_input to the field name. `label` is used as a fallback
# if the field is absent from the run input.
#
# [[tasks]]
# name             = "my-generic-linkedin"
# label            = "unknown"          # fallback if _jobsearch_label missing
# label_from_input = "_jobsearch_label" # read label from this run input field
#
# [[tasks]]
# name             = "my-generic-careersite"
# label            = "unknown"
# label_from_input = "_jobsearch_label"
# actor            = "careersite"
