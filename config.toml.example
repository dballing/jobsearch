api_token = "apify_api_xxxxxxxxxxxxxxxxxxxx"
username  = "your-apify-username"
db_path   = "jobs.db"

# Map label keys to display names shown in the UI filter bar.
# If a label has no entry here it is shown uppercased.
[labels]
dc = "DC/DMV"
nc = "NC"

[[tasks]]
name  = "my-dc-va-search"
label = "dc"             # required: short key stored in the database
# actor = "linkedin"    # optional: "linkedin" (default) or "careersite"
# exclude_ats_duplicates = true  # optional: skip results already covered by a career-site task
# reset_on_change = true         # optional: reset skipped jobs to new if description changes (default: true)

[[tasks]]
name  = "my-dc-va-search-career-sites"
label = "dc"             # same label — career-site results join the same filter group
actor = "careersite"     # use fantastic-jobs/career-site-job-listing-api

[[tasks]]
name  = "my-nc-search"
label = "nc"
